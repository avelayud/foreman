# FieldAgent Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# === AI ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === Email Sending ===
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=your_verified_sender@yourdomain.com

# === SMS (Twilio) ===
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx   # Your provisioned Twilio number

# === Google OAuth (Gmail + Calendar) ===
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# === Database ===
DATABASE_URL=sqlite:///./fieldagent.db   # Dev default
# DATABASE_URL=postgresql://user:password@localhost/fieldagent  # Prod

# === App Config ===
APP_ENV=development   # development | production
APP_PORT=8000
LOG_LEVEL=INFO

# === Agent Config ===
REACTIVATION_THRESHOLD_DAYS=365     # Contact customers inactive > this many days
DAILY_OUTREACH_LIMIT=20             # Max outreach messages per operator per day
DRY_RUN=true                        # true = generate but don't send. Set false to send.
