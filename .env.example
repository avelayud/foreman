# Foreman — Environment Variables
# Copy this file to .env and fill in your values.

# AI (required)
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=sqlite:///./foreman.db

# App
APP_ENV=development
DRY_RUN=true

# Google OAuth (for Gmail integration — Phase 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SendGrid (Phase 3)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Twilio SMS (Phase 5)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
